install.packages("palmerpenguins")
library(palmerpenguins)
data("penguins")
head(penguins)
table(penguins$species)
library(dplyr)
pg_model = penguins |> mutate(IsAdelie <- species == "Adelie")
head(pg_model)
pg_model = penguins |> mutate(IsAdelie = species == "Adelie")
head(pg_model)
?glm
tail(pg_model)
pg_model |> arrange(bill_length_mm)
pg_model |> count(species, IsAdelie)
# A logistic regression model is an example of a Generalised Linear Model (GLM)
# To fit a logistic regression (or a different GLM) we use the glm() command
# The glm function takes two main inputs -- our regression equation, and the family (type) of GLM we want
# Like with lm() our regression equation is y ~ x1 + x2 + x3... where y is our response, and x1,x2,x3 are our predictors
# In this case
model = glm(IsAdelie ~ bill_length_mm + bill_depth_mm + flipper_length_mm + body_mass_g,
# For logistic regression, the family is "binomial"
# The other commonly used GLM would be family = "poisson" if you were modelling count data
family = "binomial")
# A logistic regression model is an example of a Generalised Linear Model (GLM)
# To fit a logistic regression (or a different GLM) we use the glm() command
# The glm function takes three main inputs -- our regression equation, our data, and the family (type) of GLM we want
# Like with lm() our regression equation is y ~ x1 + x2 + x3... where y is our response, and x1,x2,x3 are our predictors
# In this case
model = glm(IsAdelie ~ bill_length_mm + bill_depth_mm + flipper_length_mm + body_mass_g,
# Our data comes from the pg_model data frame
data = pg_model
# For logistic regression, the family is "binomial"
# The other commonly used GLM would be family = "poisson" if you were modelling count data
family = "binomial")
# A logistic regression model is an example of a Generalised Linear Model (GLM)
